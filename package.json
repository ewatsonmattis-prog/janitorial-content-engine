{
  "name": "cleanreach-content-engine",
  "version": "1.0.0",
  "description": "Automated inbound content engine for CleanReach - a growth agency for commercial cleaning companies",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "generate:topic": "ts-node src/workflows/generateFromTopic.ts",
    "generate:transcript": "ts-node src/workflows/generateFromTranscript.ts",
    "generate:csv": "ts-node src/workflows/generateFromCsv.ts",
    "calendar:30": "ts-node src/workflows/generateCalendar.ts",
    "export:weekly": "ts-node src/workflows/exportWeekly.ts",
    "sync:airtable": "ts-node src/workflows/syncAirtable.ts",
    "sync:notion": "ts-node src/workflows/syncNotion.ts",
    "webhook:start": "ts-node src/workflows/webhookServer.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@notionhq/client": "^2.2.15",
    "airtable": "^0.12.2",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "marked": "^12.0.0",
    "openai": "^4.47.1",
    "ora": "^5.4.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
